# =====================================================
# ExternConnector — Linear ↔ ClickUp Sync
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# =====================================================

# Linear
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret_here
LINEAR_TEAM_ID=your_linear_team_id_here

# ClickUp
CLICKUP_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_WEBHOOK_SECRET=your_clickup_webhook_secret_here
CLICKUP_WORKSPACE_ID=your_workspace_id_here
CLICKUP_LIST_ID=your_list_id_here

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/externconnector?user=postgres&password=postgres

# App
PORT=8080
BASE_URL=http://localhost:8080
